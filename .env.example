# RetroFantasy Server - Environment (example)
#
# Copia estos nombres en `server/.env` y rellena los valores reales.
# Nunca subas `server/.env` a git.

PORT=3000
NODE_ENV=development

# URL publica del servidor en producción (Render te la da al hacer deploy)
# Ejemplo producción: https://retro-fantasy-api.onrender.com
API_URL=http://localhost:3000

# URL base del FRONTEND (usada como redirectTo en emails de recuperación de Supabase)
# Desarrollo local: ajusta al puerto de tu servidor de archivos estáticos
# Producción:      https://tu-app.pages.dev
FRONTEND_URL=http://localhost:5173
# CORS allowlist: origenes separados por comas (sin espacios)
# Desarrollo:  http://localhost:5173,http://localhost:3000
# Producción:  https://tu-app.pages.dev,https://tudominio.com
ALLOWED_ORIGINS=http://localhost:5173

# Supabase (obligatorio)
SUPABASE_URL=
SUPABASE_KEY=

# Supabase service role (recomendado para operaciones admin/RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Cron/job externo (si usas la Edge Function)
CRON_SECRET=

# Mercado por liga
MARKET_HOURS=24
MARKET_CRON_SCHEDULE=0 * * * *

